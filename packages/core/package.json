{
  "name": "@tl/core",
  "version": "0.3.0",
  "description": "Core translation pipeline with glossary enforcement and context retrieval for tl",
  "license": "MIT",
  "author": "Mohamed Omar",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/its-magdy/Translate-Local.git",
    "directory": "packages/core"
  },
  "keywords": ["translation", "glossary", "pipeline", "localization"],
  "type": "module",
  "files": ["dist/", "LICENSE", "README.md", "CHANGELOG.md"],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./pipeline": {
      "bun": "./src/pipeline.ts",
      "import": "./dist/pipeline.js",
      "types": "./dist/pipeline.d.ts"
    },
    "./glossary": {
      "bun": "./src/glossary.ts",
      "import": "./dist/glossary.js",
      "types": "./dist/glossary.d.ts"
    },
    "./context": {
      "bun": "./src/context.ts",
      "import": "./dist/context.js",
      "types": "./dist/context.d.ts"
    },
    "./config": {
      "bun": "./src/config.ts",
      "import": "./dist/config.js",
      "types": "./dist/config.d.ts"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "bun test"
  },
  "peerDependencies": {
    "@tl/shared": "workspace:*"
  },
  "devDependencies": {
    "@tl/adapters": "workspace:*",
    "@tl/shared": "workspace:*",
    "bun-types": "latest",
    "typescript": "^5.7"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
