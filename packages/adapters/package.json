{
  "name": "@tl/adapters",
  "version": "0.2.0",
  "description": "Model adapter implementations for tl (TranslateGemma via Ollama, mock)",
  "license": "MIT",
  "author": "Mohamed Omar",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/its-magdy/Translate-Local.git",
    "directory": "packages/adapters"
  },
  "keywords": ["translation", "ollama", "translategemma", "adapter"],
  "type": "module",
  "files": ["dist/", "LICENSE", "README.md", "CHANGELOG.md"],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./mock": {
      "bun": "./src/mock.ts",
      "import": "./dist/mock.js",
      "types": "./dist/mock.d.ts"
    },
    "./factory": {
      "bun": "./src/factory.ts",
      "import": "./dist/factory.js",
      "types": "./dist/factory.d.ts"
    },
    "./base": {
      "bun": "./src/base.ts",
      "import": "./dist/base.js",
      "types": "./dist/base.d.ts"
    },
    "./translate-gemma/local": {
      "bun": "./src/translate-gemma/local.ts",
      "import": "./dist/translate-gemma/local.js",
      "types": "./dist/translate-gemma/local.d.ts"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "bun test --pass-with-no-tests"
  },
  "peerDependencies": {
    "@tl/shared": "workspace:*"
  },
  "devDependencies": {
    "@tl/shared": "workspace:*",
    "bun-types": "latest",
    "typescript": "^5.7"
  }
}
