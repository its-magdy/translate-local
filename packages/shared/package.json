{
  "name": "@translate-local/shared",
  "version": "0.3.4",
  "description": "Shared types, errors, constants, and utilities for tl",
  "license": "MIT",
  "author": "Mohamed Omar",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/its-magdy/translate-local.git",
    "directory": "packages/shared"
  },
  "keywords": ["translation", "localization", "types", "utilities"],
  "type": "module",
  "files": ["dist/", "LICENSE", "README.md"],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "bun": "./src/types.ts",
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./errors": {
      "bun": "./src/errors.ts",
      "import": "./dist/errors.js",
      "types": "./dist/errors.d.ts"
    },
    "./utils": {
      "bun": "./src/utils.ts",
      "import": "./dist/utils.js",
      "types": "./dist/utils.d.ts"
    },
    "./utils/language": {
      "bun": "./src/utils/language.ts",
      "import": "./dist/utils/language.js",
      "types": "./dist/utils/language.d.ts"
    },
    "./utils/text": {
      "bun": "./src/utils/text.ts",
      "import": "./dist/utils/text.js",
      "types": "./dist/utils/text.d.ts"
    },
    "./constants": {
      "bun": "./src/constants.ts",
      "import": "./dist/constants.js",
      "types": "./dist/constants.d.ts"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "bun test"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.7"
  }
}
