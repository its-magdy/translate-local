{
  "name": "@translate-local/cli",
  "version": "0.3.3",
  "private": true,
  "type": "module",
  "bin": {
    "tl": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "build:bin": "bun build --compile --minify --sourcemap ./src/index.ts --outfile dist/tl",
