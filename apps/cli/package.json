    "@translate-local/core": "workspace:*",
    "@translate-local/shared": "workspace:*",
    "@translate-local/tui": "workspace:*",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.7"
  }
}
